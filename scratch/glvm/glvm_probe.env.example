# Copy this file to scratch/glvm/glvm_probe.env and edit values locally.
# Do not commit real hostnames, users, ports, keys, or absolute machine paths.

MACOS=LOCAL
WINSSH=
PISSH=

# Windows SSH may land in Windows OpenSSH instead of inside WSL.
# Use "wsl bash -s" for Windows OpenSSH, or "bash -s" if SSH lands directly in WSL.
WIN_REMOTE_SHELL='wsl bash -s'
PI_REMOTE_SHELL='bash -s'

# Optional extra ssh args. Examples:
# SSH_OPTS='-p 2222'
# SSH_OPTS='-F path/to/repo-relative/ssh_config'
SSH_OPTS=
